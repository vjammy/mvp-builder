{
  "name": "manoa-method",
  "version": "1.0.0",
  "description": "A local, markdown-first planning and gating system for AI-assisted builds in Codex, Claude Code, and OpenCode",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "npm run smoke",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke-test.ts",
    "create-project": "tsx scripts/manoa-create-project.ts",
    "validate": "tsx scripts/manoa-validate.ts",
    "next-phase": "tsx scripts/manoa-next-phase.ts",
    "status": "tsx scripts/manoa-status.ts",
    "test:quality-regression": "tsx scripts/test-quality-regression.ts",
    "autoresearch": "tsx scripts/manoa-autoresearch.ts",
    "orchestrate": "tsx scripts/manoa-orchestrate.ts",
    "orchestrate:dry-run": "tsx scripts/manoa-orchestrate.ts --dry-run=true",
    "score": "tsx scripts/manoa-score.ts",
    "gates": "tsx scripts/manoa-gates.ts",
    "recover": "tsx scripts/manoa-recover.ts",
    "manoa": "tsx scripts/manoa-cli.ts",
    "swarm:build-10": "tsx scripts/run-10-app-swarm.ts build",
    "swarm:score": "tsx scripts/run-10-app-swarm.ts score",
    "swarm:gates": "tsx scripts/run-10-app-swarm.ts gates",
    "swarm:report": "tsx scripts/run-10-app-swarm.ts report",
    "finalize:release": "tsx scripts/manoa-finalize-repo-release.ts"
  },
  "dependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "jszip": "^3.10.1",
    "next": "^14.2.5",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
